<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Ignora feeds herdados (ex.: feed privado do Azure DevOps da maquina) e usa apenas o nuget.org publico. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
